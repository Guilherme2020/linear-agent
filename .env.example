# -----------------------------------------------------------------------------
# Omni — API do servidor local
# -----------------------------------------------------------------------------
# URL da API do Omni (padrão após omni install)
OMNI_API_URL=http://localhost:8882

# API key gerada pelo `omni install` (busque em ~/.omni/config.json se perder)
OMNI_API_KEY=omni_sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID da instância WhatsApp (gerado pelo `omni instances create`)
OMNI_INSTANCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# -----------------------------------------------------------------------------
# GitHub MCP
# -----------------------------------------------------------------------------
# Personal Access Token do GitHub
# Criar em: https://github.com/settings/tokens
# Escopos necessários: repo, read:org, read:user
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Linear
# -----------------------------------------------------------------------------
# Claude Code usa OAuth (gerenciado automaticamente via `claude mcp add`).
# Para rodar os testes de integração diretamente (bun test), crie uma
# personal API key em: linear.app/settings/api
LINEAR_API_KEY=lin_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID do time usado nos testes (UUID — visível na URL ao abrir o time no Linear)
LINEAR_TEAM_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Anthropic (opcional — só necessário se não usar claude.ai Pro/Max)
# -----------------------------------------------------------------------------
# Se você usa claude.ai Pro ou Max, não precisa desta variável.
# Necessária apenas para autenticação via API key direta.
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
